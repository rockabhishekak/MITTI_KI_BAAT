# ============================================================
#   MITTI KI BAAT - Environment Variables File
#   Copy this file, rename it to ".env", and fill in your
#   own values. NEVER share your .env file with anyone.
# ============================================================


# ------------------------------------------------------------
# PORT
# The port number on which the server will run.
# Default is 5000. You can change it to 3000, 8000, etc.
# After starting the server, open: http://localhost:5000
# ------------------------------------------------------------
PORT=5000


# ------------------------------------------------------------
# MONGODB_URI  (Database Connection String)
#
# HOW TO GET THIS:
# Step 1: Go to https://www.mongodb.com/cloud/atlas and sign up for FREE
# Step 2: Create a new Project (give any name, e.g. "MittiKiBaat")
# Step 3: Click "Build a Database" → choose "M0 FREE" tier
# Step 4: Choose a cloud provider (AWS is fine) and click "Create"
# Step 5: Set a username and password (remember these!)
# Step 6: Under "Network Access", click "Add IP Address" → "Allow Access from Anywhere"
# Step 7: Go to your cluster, click "Connect" → "Connect your application"
# Step 8: Copy the connection string — it looks like:
#         mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/?retryWrites=true&w=majority
# Step 9: Replace <username> and <password> with what you set in Step 5
# Step 10: Paste the full string below after the = sign
#
# Example (DO NOT use this — it is just an example):
# MONGODB_URI=mongodb+srv://myuser:mypassword@cluster0.abc12.mongodb.net/mittiDB?retryWrites=true&w=majority
# ------------------------------------------------------------
MONGODB_URI=mongodb+srv://<username>:<password>@cluster0.xxxxx.mongodb.net/mittiDB?retryWrites=true&w=majority


# ------------------------------------------------------------
# JWT_SECRET  (JSON Web Token Secret Key)
#
# WHAT IS THIS?
# When a user logs in, the server creates a special "token" (like a digital
# ID card) and signs it with this secret key. The frontend sends this token
# back with every request to prove who it is.
#
# HOW TO GENERATE A GOOD SECRET:
# Option 1: Type any long random string (e.g. "mitti_ki_baat_super_secret_2024")
# Option 2: Run this in your terminal:
#           node -e "console.log(require('crypto').randomBytes(32).toString('hex'))"
#
# IMPORTANT: Keep this value private and never commit it to GitHub.
# ------------------------------------------------------------
JWT_SECRET=replace_this_with_a_long_random_secret_key
